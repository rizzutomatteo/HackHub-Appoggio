@startuml CLASSI_ANALISI_HackHub
' Diagramma delle CLASSI DI ANALISI - 1a iterazione HackHub.
' Solo concetti del dominio di business (no boundary/control): cfr. docs/UML_03_Class.pdf slide 11.
' Coerente con useCase.puml e CASI_USO_REALIZZATI.md
' (Crea Hackathon, Crea Team, Iscrive Team, Invia Sottomissione, Valuta Sottomissione).
hide empty members
hide circle

enum Stato {
  InIscrizione
  InCorso
  InValutazione
  Concluso
}

class Utente <<entità>> {
  nome
  email
  --
  creaTeam()
  accettaInvito()
}

class Hackathon <<entità>> {
  nome
  regolamento
  scadenzaIscrizioni
  dataInizio
  dataFine
  luogo
  montepremi
  dimensioneMaxTeam
  stato : Stato
  --
  avanzaStato()
  verificaComposizioneStaff()
  elencaSottomissioni()
}

class Team <<entità>> {
  nome
  --
  aggiungiMembro()
  iscriviA()
  inviaSottomissione()
}

class Iscrizione <<entità>> {
  --
  registra()
  verificaIscrivibilita()
}

class Sottomissione <<entità>> {
  titolo
  contenuto
  dataOra
  --
  creaOAggiorna()
  registraDataOra()
}

class Valutazione <<entità>> {
  giudizio
  punteggio
  --
  validaPunteggio()
  registra()
}

' ===== Ruoli staff e partecipazione (ruoli sull'estremita' Utente, molteplicita' su ENTRAMBE) =====
Utente "1\norganizzatore"    -- "*" Hackathon
Utente "1\ngiudice"          -- "*" Hackathon
Utente "1..*\nmentore"       -- "*" Hackathon
Team "0..1" -- "1..*\nmembro"        Utente
Team "0..1" -- "1\namministratore"   Utente

' ===== Iscrizione (reifica Team-Hackathon) e catena del valore =====
Team       "1" -- "*" Iscrizione : effettua >
Hackathon  "1" -- "*" Iscrizione : raccoglie >
Iscrizione "1" *-- "0..1" Sottomissione
Sottomissione "1" *-- "0..1" Valutazione
Valutazione "*" -- "1\ngiudice" Utente

note bottom of Valutazione
  Vincolo: il giudice di una Valutazione coincide con il
  giudice assegnato all'Hackathon della relativa Iscrizione.
endnote

legend right
  Classi di analisi (dominio di business), stereotipo «entità».
  Lo "stato" e' un attributo/enum; ciclo di vita (pattern State),
  persistenza e controller sono scelte di PROGETTAZIONE (fuori da questo diagramma).
endlegend

@enduml
